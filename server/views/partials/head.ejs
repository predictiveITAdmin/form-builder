<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | Platform Docs
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary-color: #2596be;
            --secondary-color: #0d8609;
            --text-color: #1f2937;
            --bg-color: #f9fafb;
            --border-color: #e5e7eb;
            --card-bg: #ffffff;
            --sidebar-width: 260px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: var(--text-color);
            background-color: var(--bg-color);
            line-height: 1.6;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styling */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--card-bg);
            border-right: 1px solid var(--border-color);
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            padding: 2rem 1rem;
        }

        .sidebar-brand {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary-color);
            margin-bottom: 2rem;
            padding-left: 0.5rem;
        }

        .nav-section {
            margin-bottom: 1.5rem;
        }

        .nav-section-title {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6b7280;
            font-weight: 600;
            margin-bottom: 0.5rem;
            padding-left: 0.5rem;
        }

        .nav-menu {
            list-style: none;
        }

        .nav-item a {
            display: block;
            padding: 0.5rem;
            color: #4b5563;
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.95rem;
            transition: background-color 0.2s, color 0.2s;
        }

        .nav-item a:hover {
            background-color: #f3f4f6;
            color: #111827;
        }

        .nav-item a.active {
            background-color: #ebf8ff;
            color: var(--primary-color);
            font-weight: 600;
            border-left: 3px solid var(--primary-color);
            padding-left: calc(0.5rem - 3px);
            border-radius: 0 6px 6px 0;
        }

        .nav-sub-menu {
            list-style: none;
            margin-left: 1.25rem;
            margin-top: 0.25rem;
            margin-bottom: 0.25rem;
            border-left: 1px solid var(--border-color);
        }

        .nav-sub-item a {
            display: block;
            padding: 0.35rem 0.75rem;
            color: #6b7280;
            text-decoration: none;
            font-size: 0.85rem;
            border-radius: 4px;
            transition: color 0.2s, background-color 0.2s;
        }

        .nav-sub-item a:hover {
            color: var(--primary-color);
            background-color: #f9fafb;
        }

        .nav-sub-item a.active {
            color: var(--primary-color);
            font-weight: 500;
            background-color: #f3f4f6;
        }

        /* Breadcrumbs */
        .breadcrumbs {
            display: flex;
            align-items: center;
            list-style: none;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
            color: #6b7280;
            margin-left: 0;
        }

        .breadcrumbs li {
            margin-bottom: 0;
            display: flex;
            align-items: center;
        }

        .breadcrumbs li:not(:last-child)::after {
            content: "›";
            margin: 0 0.5rem;
            color: #9ca3af;
            font-size: 1.25rem;
            line-height: 1;
        }

        .breadcrumbs a {
            color: var(--primary-color);
            text-decoration: none;
            transition: color 0.2s;
        }

        .breadcrumbs a:hover {
            text-decoration: underline;
        }

        .breadcrumbs .current {
            color: #374151;
            font-weight: 500;
        }

        /* Main Content Styling */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 3rem 4rem;
            max-width: calc(100% - var(--sidebar-width));
        }

        .content-container {
            max-width: 100%;
        }

        header {
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 1rem;
            margin-bottom: 2rem;
        }

        h1 {
            color: var(--primary-color);
            font-size: 2.25rem;
            margin-bottom: 0.5rem;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        h2 {
            font-size: 1.5rem;
            margin-top: 2.5rem;
            margin-bottom: 1.25rem;
            color: var(--secondary-color);
            font-weight: 600;
            border-bottom: 2px solid #f3f4f6;
            padding-bottom: 0.5rem;
        }

        h3 {
            font-size: 1.25rem;
            margin-top: 2rem;
            margin-bottom: 0.75rem;
            color: var(--secondary-color);
            font-weight: 600;
        }

        p {
            margin-bottom: 1.25rem;
            color: #4b5563;
        }

        ul,
        ol {
            margin-left: 1.5rem;
            margin-bottom: 1.5rem;
            color: #4b5563;
        }

        li {
            margin-bottom: 0.5rem;
        }

        /* Code & Preformatted Text */
        pre {
            background-color: #1e293b;
            color: #f8fafc;
            padding: 1.25rem;
            border-radius: 8px;
            overflow-x: auto;
            margin-bottom: 1.5rem;
            box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
        }

        code {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.875rem;
            background-color: #f1f5f9;
            padding: 0.2rem 0.4rem;
            border-radius: 4px;
            color: #be185d;
        }

        pre code {
            background-color: transparent;
            padding: 0;
            color: inherit;
        }

        /* Keyboard Shortcuts */
        kbd {
            background-color: #f8fafc;
            border: 1px solid #cbd5e1;
            border-bottom-width: 2px;
            border-radius: 4px;
            padding: 0.15rem 0.4rem;
            font-size: 0.8em;
            font-family: ui-monospace, monospace;
            color: #334155;
            white-space: nowrap;
        }

        /* Blockquotes */
        blockquote {
            border-left: 4px solid var(--primary-color);
            background-color: #f0f9ff;
            padding: 1rem 1.5rem;
            margin: 0 0 1.5rem 0;
            color: #334155;
            font-style: italic;
            border-radius: 0 8px 8px 0;
        }

        blockquote p:last-child {
            margin-bottom: 0;
        }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            background-color: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
        }

        th,
        td {
            padding: 0.875rem 1rem;
            border-bottom: 1px solid var(--border-color);
            text-align: left;
            vertical-align: top;
        }

        th {
            background-color: #f8fafc;
            color: #475569;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background-color: #f8fafc;
        }

        .badge {
            display: inline-block;
            padding: 0.25em 0.8em;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-radius: 9999px;
            background-color: #e5f6e8;
            color: var(--secondary-color);
            margin-bottom: 1rem;
        }

        .sub-header {
            font-size: 0.875rem;
            color: #6b7280;
            margin-top: 0.2rem;
            font-weight: 400;
        }

        /* Hero Banner */
        .hero-banner {
            position: relative;
            overflow: hidden;
            padding: 2.75rem 3rem;
            border-radius: 12px;
            margin-bottom: 2.5rem;
            color: #fff;

            /* Professional base + upgraded gradient depth */
            background:
                radial-gradient(900px 500px at 85% 10%, rgba(59, 130, 246, 0.28), transparent 60%),
                radial-gradient(700px 420px at 10% 90%, rgba(99, 102, 241, 0.22), transparent 55%),
                linear-gradient(135deg, #1a3263 0%, #0f2a63 45%, #134e9e 100%);

            box-shadow:
                0 18px 35px rgba(2, 6, 23, 0.18),
                inset 0 1px 0 rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.10);
        }

        /* Subtle grid = “documentation” energy */
        .hero-banner::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 42px 42px;
            opacity: 0.18;
            mask-image: radial-gradient(circle at 30% 20%, #4263a0 0%, transparent 65%);
        }

        /* Soft highlight blob, NOT loud */
        .hero-banner::after {
            content: "";
            position: absolute;
            inset: -40%;
            pointer-events: none;
            background: radial-gradient(circle at 70% 25%, rgba(255, 255, 255, 0.14), transparent 45%);
            opacity: 0.6;
        }

        .hero-banner .badge {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .35rem .65rem;
            font-size: .75rem;
            font-weight: 600;
            letter-spacing: .05em;
            border-radius: 999px;

            background: rgba(255, 255, 255, 0.10);
            border: 1px solid rgba(255, 255, 255, 0.14);
            backdrop-filter: blur(8px);
        }

        .hero-banner h1 {
            margin-top: 0.6rem;
            margin-bottom: 0.4rem;
            font-size: 2.2rem;
            font-weight: 600;
            line-height: 1.2;
            color: white;
        }

        .hero-banner p {
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.85);
            max-width: 640px;
            line-height: 1.6;
        }

        /* Info Panels */
        .panel {
            padding: 1.25rem 1.5rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            border-left: 4px solid;
            background-color: #f8fafc;
        }

        .panel-title {
            font-weight: 600;
            font-size: 1.05rem;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
        }

        .panel p:last-child,
        .panel ul:last-child {
            margin-bottom: 0;
        }

        .panel-info {
            border-left-color: var(--primary-color);
            background-color: #eff6ff;
        }

        .panel-info .panel-title {
            color: #1e40af;
        }

        .panel-success {
            border-left-color: var(--secondary-color);
            background-color: #f0fdf4;
        }

        .panel-success .panel-title {
            color: #166534;
        }

        .panel-warning {
            border-left-color: #f59e0b;
            background-color: #fffbeb;
        }

        .panel-warning .panel-title {
            color: #b45309;
        }

        /* Document Section Cards */
        .doc-section {
            background: var(--card-bg);
            padding: 2.5rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            margin-bottom: 2rem;
        }

        .doc-section h2:first-of-type {
            margin-top: 0;
        }

        /* Accordions */
        details.accordion {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            margin-bottom: 1rem;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }

        details.accordion summary {
            padding: 1.25rem 1.5rem;
            font-weight: 600;
            cursor: pointer;
            background-color: #f9fafb;
            list-style: none;
            position: relative;
            user-select: none;
            color: #374151;
            transition: background-color 0.3s ease, color 0.3s ease, border-radius 0.3s ease;
            border-radius: 8px;
        }

        details.accordion summary:hover {
            background-color: #f3f4f6;
        }

        details.accordion summary::-webkit-details-marker {
            display: none;
        }

        details.accordion summary::after {
            content: '+';
            position: absolute;
            right: 1.5rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.25rem;
            color: #9ca3af;
            font-weight: 400;
            transition: transform 0.3s ease, color 0.3s ease;
        }

        details.accordion[open] summary::after {
            content: '−';
            color: var(--primary-color);
            transform: translateY(-50%) rotate(90deg);
        }

        details.accordion[open] summary {
            border-bottom: 1px solid var(--border-color);
            background-color: var(--card-bg);
            color: var(--primary-color);
            border-bottom-left-radius: 0;
            border-bottom-right-radius: 0;
        }

        .accordion-content {
            padding: 1.5rem;
            color: #4b5563;
            animation: accordionSlideDown 0.3s ease-out forwards;
            transform-origin: top;
        }

        @keyframes accordionSlideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .accordion-content> :last-child {
            margin-bottom: 0;
        }

        /* Responsive */
        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                position: relative;
                height: auto;
                border-right: none;
                border-bottom: 1px solid var(--border-color);
            }

            .main-content {
                margin-left: 0;
                padding: 2rem;
                max-width: 100%;
            }
        }
    </style>
</head>